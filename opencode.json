{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": "allow"
  },
  "agent": {
    "orchestrator": {
      "name": "orchestrator",
      "description": "协调复杂任务，将任务分配给专门的子模式",
      "mode": "primary",
      "temperature": 0.3,
      "prompt": "{file:./.opencode/prompts/orchestrator.txt}",
      "permission": {
        "bash": "deny",
        "read": "deny",
        "grep": "deny",
        "glob": "deny",
        "edit": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "question": "allow",
        "task": {
          "*": "deny",
          "architect": "allow",
          "code": "allow",
          "ask": "allow",
          "debug": "allow",
          "review": "allow"
        }
      }
    }
  }
}